{
  "schemaVersion": 1,
  "id": "fastchunk",
  "version": "${version}",
  "name": "FastChunk",
  "description": "Speeds up chunk rendering via threaded building, culling, and smart update batching. Optimized for low-end and mobile devices.",
  "authors": ["ArgonClient"],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.fastchunk.FastChunkMod"
    ]
  },
  "mixins": [
    "fastchunk.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.15.11",
    "minecraft": "~1.21",
    "java": ">=21",
    "fabric-api": "*"
  }
}
